// Driver for Lansen LAN-WMBUS-O-P Outdoor Pulse Counter
driver {
    name           = lansenop
    meter_type     = PulseCounter
    default_fields = name,id,status,meter_datetime,a_counter,software_version,timestamp

    detect {
        mvt = LAS,0A,37
        mvt = LAS,28,00
    }

    library {
        use = meter_datetime
    }

    fields {
        // DR2: Number of pulses (32-bit integer, VIF=FD, VIFE=3A, Dimensionless)
        field {
            name         = a
            quantity     = Dimensionless
            vif_scaling  = None
            info         = 'The current number of counted pulses from counter a.'
            match {
                measurement_type = Instantaneous
                vif_range        = Dimensionless
                storage_nr       = 0
            }
        }

        // DR3: Error flags (16-bit, DIF=02 VIF=FD VIFE=97 VIFE=1D)
        // Note: Only visible for software version older than 46
        field {
            name       = error_flags
            quantity   = Text
            info       = 'Error flags reported by the meter (only firmware < 46).'
            match {
                measurement_type = Instantaneous
                vif_range        = ErrorFlags
            }
            lookup {
                name            = ERROR_FLAGS
                map_type        = BitToString
                mask_bits       = 0xffff
                default_message = OK
                map {
                    name  = LOW_BATTERY
                    info  = 'Low battery - 18 months before end of life'
                    value = 0x04
                    test  = Set
                }
            }
        }

        // DR4: Number of pulses storage 1 (Due date #0)
        // Note: Only included if Due date 0 parameter is active
        field {
            name         = a_at_due_date_0
            quantity     = Dimensionless
            vif_scaling  = None
            info         = 'Number of pulses stored at due date 0.'
            match {
                measurement_type = Instantaneous
                vif_range        = Dimensionless
                storage_nr       = 1
            }
        }

        // DR5: Time storage 1 - Due date and time #0
        // Note: Only included if Due date 0 parameter is active
        field {
            name         = due_date_0
            quantity     = PointInTime
            display_unit = datetime
            info         = 'Due date and time for storage 0.'
            match {
                measurement_type = Instantaneous
                vif_range        = DateTime
                storage_nr       = 1
            }
        }

        // DR6: Number of pulses storage 2 (Due date #1)
        // Note: Only included if Due data 1 parameter is active
        field {
            name         = a_at_due_date_1
            quantity     = Dimensionless
            vif_scaling  = None
            info         = 'Number of pulses stored at due date 1.'
            match {
                measurement_type = Instantaneous
                vif_range        = Dimensionless
                storage_nr       = 2
            }
        }

        // DR7: Time storage 2 - Due date and time #1
        // Note: Only included if Due data 1 parameter is active
        field {
            name         = due_date_1
            quantity     = PointInTime
            display_unit = datetime
            info         = 'Due date and time for storage 1.'
            match {
                measurement_type = Instantaneous
                vif_range        = DateTime
                storage_nr       = 2
            }
        }

        // DR8: Number of pulses storage 3 (Due date #2)
        // Note: Only included if Due data 2 parameter is active
        field {
            name         = a_at_due_date_2
            quantity     = Dimensionless
            vif_scaling  = None
            info         = 'Number of pulses stored at due date 2.'
            match {
                measurement_type = Instantaneous
                vif_range        = Dimensionless
                storage_nr       = 3
            }
        }

        // DR9: Time storage 3 - Due date and time #2
        // Note: Only included if Due data 2 parameter is active
        field {
            name         = due_date_2
            quantity     = PointInTime
            display_unit = datetime
            info         = 'Due date and time for storage 2.'
            match {
                measurement_type = Instantaneous
                vif_range        = DateTime
                storage_nr       = 3
            }
        }

        // DR10: Software version (16-bit integer, VIF=FD, VIFE=0F)
        field {
            name         = software_version
            quantity     = Text
            match {
                measurement_type = Instantaneous
                vif_range        = SoftwareVersion
            }
        }

        // Status from TPL status field (byte 21)
        // Bit 2 (0x04) = Low battery
        field {
            name         = status
            quantity     = Text
            attributes   = INCLUDE_TPL_STATUS
        }
    }

    tests {
        test {
            args     = 'MyPulseCounter lansenop 00211206 4164B599F0C39587B449CC920C59BCA8'
            comment  = 'Test Lansen outdoor pulse counter with AES-CBC encrypted telegram'
            telegram = 686a6a6808fd720612210033300a37130000000c7878582600066d49332e4f363601fd71d58c4078000000008140fdf19474ff0dfd3b3736443330061221000a37720612210033302800e6002005d7dfae90e46bfbce5197edad630e9a73ef50b1bf082d0d64daa680af036288151d16
            json     = '{"_":"telegram","media":"other","meter":"lansenop","name":"MyPulseCounter","id":"00211206","meter_datetime":"2000-06-30 07:36","a_counter":2,"software_version":"003B","status":"OK","timestamp":"1111-11-11T11:11:11Z"}'
            fields   = 'MyPulseCounter;00211206;OK;2000-06-30 07:36;2;003B;1111-11-11 11:11.11'
        }
    }
}
